{
  "name": "sales-intelligence-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item .next -Recurse -Force }\"",
    "dev": "next dev",
    "build": "next build",
    "build:isolated": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:NEXT_DIST_DIR='.next-build'; npm run build\"",
    "start": "next start",
    "lint": "eslint src next.config.ts eslint.config.mjs prettier.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@react-pdf/renderer": "^4.2.1",
    "@tanstack/react-query": "^5.68.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-dropzone": "^14.3.8",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.21.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "vitest": "^4.1.10"
  }
}
